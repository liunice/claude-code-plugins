# =============================================================================
# search-skills environment variables — REFERENCE ONLY
# Do NOT copy this file. Set these variables in ~/.claude/settings.json
# under the "env" field. Run /search-skills:setup for guided configuration.
# At least ONE standard search source API key (BRAVE / EXA / TAVILY / GROK) is required.
# TWITTER is opt-in only and cannot serve as the sole source.
# =============================================================================

# --- Search sources (at least one standard source required; unconfigured sources are skipped) ---

# Brave Search — https://brave.com/search/api/
BRAVE_API_KEY=

# Exa — https://exa.ai (semantic search, good for technical/academic content)
EXA_API_KEY=
# EXA_API_URL=https://api.exa.ai

# Tavily — https://tavily.com (web search with AI answer, good for general/news)
TAVILY_API_KEY=
# TAVILY_API_URL=https://api.tavily.com

# Grok — xAI model via OpenAI-compatible API (strong real-time knowledge)
# Only GROK_API_KEY is required; URL and model have sensible defaults.
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.20-beta

# Twitter — X/Twitter tweet search via twitterapi.io (NOT the official X/Twitter API)
# Opt-in source: only runs when explicitly requested via --source twitter
# Get your API key at: https://twitterapi.io
TWITTER_API_KEY=

# --- Timeout settings (optional) ---

# Timeout in seconds for Grok API requests (default: 120)
GROK_TIMEOUT=120
# Timeout in seconds for Brave/Exa/Tavily API requests (default: 30)
SEARCH_TIMEOUT=30

# --- MinerU (optional, only needed for anti-crawl / PDF extraction) ---

# MinerU token — https://mineru.net/apiManage/token
MINERU_TOKEN=
